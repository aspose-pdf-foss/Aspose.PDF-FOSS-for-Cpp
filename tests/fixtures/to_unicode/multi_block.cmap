%!PS-Adobe-3.0 Resource-CMap
%% 2-byte ToUnicode CMap whose mappings are split across MORE THAN
%% ONE block of a kind. Exercises:
%%  - a single 2-byte codespace (Identity-H shape)
%%  - a first beginbfchar block
%%  - a beginbfrange block in between
%%  - a SECOND beginbfchar block whose entries must also be parsed
%% A parser that only reads the first block of each kind drops the
%% trailing codes (mirrors the real-world Identity-H + ToUnicode
%% fonts emitted by office suites, which split bfchar across blocks).
/CIDInit /ProcSet findresource begin
12 dict begin
begincmap
/CIDSystemInfo << /Registry (Adobe) /Ordering (UCS) /Supplement 0 >> def
/CMapName /Adobe-Identity-UCS def
/CMapType 2 def
1 begincodespacerange
<0000> <FFFF>
endcodespacerange
2 beginbfchar
<0041> <0061>
<0042> <0062>
endbfchar
1 beginbfrange
<0050> <0052> <0070>
endbfrange
2 beginbfchar
<0060> <0078>
<0061> <0079>
endbfchar
endcmap
CMapName currentdict /CMap defineresource pop
end
end
